# .env.example
#
# Copy this file to .env and fill in real values before running.
# Never commit .env to version control.
#
# Quick start:
#   cp .env.example .env
#   # edit .env with your values
#   python -c "import secrets; print(secrets.token_hex(32))"  # generate FLASK_SECRET_KEY

# ---------------------------------------------------------------
# Flask
# ---------------------------------------------------------------
FLASK_SECRET_KEY=replace-with-a-long-random-string

# ---------------------------------------------------------------
# Email (Gmail SMTP)
# Use a Gmail App Password, NOT your account password.
# Guide: https://support.google.com/accounts/answer/185833
# ---------------------------------------------------------------
EMAIL_USER=your_address@gmail.com
EMAIL_PASS=your_app_password_here

# ---------------------------------------------------------------
# Face recognition
# ---------------------------------------------------------------
# -1 = CPU (default), 0 = first GPU
INSIGHTFACE_CTX_ID=-1

# Cosine similarity threshold for a face to count as a match.
FACE_MATCH_THRESHOLD=0.7

# Minimum minutes between consecutive attendance marks for the same student.
REATTENDANCE_INTERVAL_MINUTES=10

# ---------------------------------------------------------------
# Paths (leave as defaults unless you move the files)
# ---------------------------------------------------------------
DB_FILE=database.db
ENCODE_FILE_BASE=EncodeFile_Insight
KNOWN_FACES_DIR=known_faces
