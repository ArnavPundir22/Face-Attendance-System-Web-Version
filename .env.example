# .env.example
#
# BioSecure AI — Environment Variables
#
# Copy this file to .env and fill in your real values before running.
# NEVER commit .env to version control.
#
# Quick setup:
#   cp .env.example .env
#   # Edit .env with your credentials
#   python -c "import secrets; print(secrets.token_hex(32))"  # → FLASK_SECRET_KEY

# ---------------------------------------------------------------
# Flask
# ---------------------------------------------------------------
FLASK_SECRET_KEY=replace-with-a-long-random-string

# ---------------------------------------------------------------
# Supabase  (Project Settings → API)
# ---------------------------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-public-key-here

# ---------------------------------------------------------------
# Email (Gmail SMTP) — Optional
# Leave blank to disable email-based attendance reports.
# Use a Gmail App Password, NOT your account password.
# Guide: https://support.google.com/accounts/answer/185833
# ---------------------------------------------------------------
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_gmail_app_password

# ---------------------------------------------------------------
# Face Recognition
# ---------------------------------------------------------------
# -1 = CPU (default, works everywhere), 0 = first CUDA GPU
INSIGHTFACE_CTX_ID=-1

# Cosine similarity threshold — lower is stricter (0.3 is optimal for buffalo_l)
FACE_MATCH_THRESHOLD=0.3

# Minimum minutes between consecutive marks for the same student in the same lecture
REATTENDANCE_INTERVAL_MINUTES=10

# ---------------------------------------------------------------
# Security
# ---------------------------------------------------------------
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
MIN_PASSWORD_LENGTH=8

# ---------------------------------------------------------------
# Paths (change only if you relocate directories)
# ---------------------------------------------------------------
KNOWN_FACES_DIR=known_faces

# ---------------------------------------------------------------
# Logging
# ---------------------------------------------------------------
# Levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
